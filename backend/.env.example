# LLM API Keys (Priority: Gemini -> Groq)
# You can use either one or both. The system will try Gemini first, then fall back to Groq.

# Option 1: Google Gemini (Recommended - Free tier available)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key

# Option 2: Groq (Alternative - Very fast inference)
# Get your key from: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here

# Database Configuration
# Option 1: SQLite (Local, no setup needed)
DATABASE_URL=sqlite:///./chinook.db

# Option 2: PostgreSQL (Supabase or any PostgreSQL)
# Get Supabase connection string from: Project Settings > Database > Connection String (URI)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# DATABASE_URL=postgresql://user:password@host:port/database

# Choose database type: 'sqlite' or 'postgresql'
DATABASE_TYPE=postgresql
DATABASE_URL=Supabase_Connection_string
